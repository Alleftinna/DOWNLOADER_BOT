# Конфигурация Телеграм Бота
BOT_TOKEN=your_telegram_bot_token

# Конфигурация сервиса Cobalt
COBALT_API_URL=http://cobalt-api:9000
COBALT_API_KEY=your_cobalt_api_key_if_needed

# Fallback downloader service
DOWNLOADER_URL=http://downloader:8899
DOWNLOADER_POLL_INTERVAL_SECONDS=2
DOWNLOADER_TIMEOUT_SECONDS=300

# yt-dlp cookies (Netscape format) for fallback downloader
# Place file on host: /root/cobalt/ytdlp_cookies.txt

# Video processing
VIDEO_QUALITY=480
MAX_SINGLE_FILE_SIZE_MB=45
MAX_TOTAL_FILE_SIZE_MB=500
SEGMENT_DURATION=120

# Bot behavior
ALLOWED_GROUP_ID=-1002185211541
RESTRICTED_THREADS=8740
DATA_DIR=data

# Relay: main bot → business bot → downloader bot (private) → main bot → user chat
RELAY_TIMEOUT_SECONDS=120
RELAY_OWNER_USER_ID=your_telegram_user_id
BUSINESS_BOT_URL=http://business-bot:8898

# Business bot (separate token, Telegram Business Chatbot)
BUSINESS_BOT_TOKEN=your_business_bot_token
BUSINESS_API_PORT=8898
# Fallback if data/business_connection.json is missing after docker recreate:
# BUSINESS_CONNECTION_ID=your_connection_id_from_logs
# Downloader bot peer (owner must /start the bot from RELAY_OWNER_USER_ID account first)
DOWNLOADER_BOT_USER_ID=downloader_bot_user_id
# Recommended: set username for matching (e.g. TIKTOKDOWNLOADROBOT)
DOWNLOADER_BOT_USERNAME=TIKTOKDOWNLOADROBOT
# Telegram user id of the main bot (7840843047 = @VIDEOS_SCRAPPER_BOT from logs)
MAIN_BOT_USER_ID=7840843047

# Cobalt cookies
COOKIES_SAVE_PATH=/root/cobalt/cookies.json
COOKIE_UPDATE_INTERVAL_HOURS=12
