# Конфигурация Телеграм Бота
BOT_TOKEN=your_telegram_bot_token

# Сервис скачивания (Flask + yt-dlp), в Docker по умолчанию задаётся в compose
DOWNLOADER_API_URL=http://downloader:8899
# Интервал опроса /api/status (сек) и максимальное ожидание задачи (сек)
DOWNLOAD_POLL_INTERVAL=1.5
DOWNLOAD_MAX_WAIT=330